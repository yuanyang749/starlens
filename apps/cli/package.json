{
  "name": "@starlens-app/cli",
  "version": "0.3.0",
  "description": "Starlens CLI — manage your GitHub starred repositories from the terminal",
  "type": "module",
  "bin": {
    "stars": "src/index.mjs"
  },
  "files": [
    "src/",
    "skills/",
    "README.md"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "github",
    "stars",
    "cli",
    "starlens"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "node src/index.mjs",
    "pretest": "node ../../scripts/sync-skill.mjs",
    "test": "node --test src/test/*.test.mjs",
    "prepack": "node ../../scripts/sync-skill.mjs"
  }
}
