{
  "name": "starlens",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "postinstall": "node scripts/sync-skill.mjs",
    "sync:skill": "node scripts/sync-skill.mjs",
    "build:packages": "corepack pnpm --filter @starlens-app/core build && corepack pnpm --filter @starlens-app/agent-tools build",
    "publish:packages": "pnpm build:packages && cd packages/core && npm publish --access public && cd ../../packages/agent-tools && npm publish --access public && cd ../../apps/mcp && npm publish --access public && cd ../cli && npm publish --access public && cd ../..",
    "dev": "node scripts/with-env.mjs .env -- corepack pnpm --filter @starlens/web dev",
    "dev:mobile": "node scripts/with-env.mjs .env -- corepack pnpm --filter @starlens/mobile dev",
    "dev:local": "node scripts/with-env.mjs .env -- corepack pnpm --filter @starlens/web dev",
    "build": "corepack pnpm --filter @starlens/web build",
    "build:mobile": "corepack pnpm --filter @starlens/mobile build",
    "lint": "corepack pnpm --filter @starlens/web lint",
    "lint:mobile": "corepack pnpm --filter @starlens/mobile lint",
    "test": "corepack pnpm --filter @starlens/web test",
    "test:mobile": "corepack pnpm --filter @starlens/mobile test",
    "mcp:start": "corepack pnpm --filter @starlens/mcp start",
    "db:generate": "corepack pnpm --filter @starlens/web db:generate",
    "db:migrate": "corepack pnpm --filter @starlens/web db:migrate",
    "db:migrate:local": "node scripts/with-env.mjs .env -- corepack pnpm --filter @starlens/web db:migrate",
    "db:migrate:neon": "node scripts/with-env.mjs .env.neon -- corepack pnpm --filter @starlens/web db:migrate",
    "db:check:local": "corepack pnpm --filter @starlens/web exec node scripts/check-db.mjs ../../.env",
    "db:check:neon": "corepack pnpm --filter @starlens/web exec node scripts/check-db.mjs ../../.env.neon",
    "check:api-shims": "node scripts/check-api-shims.mjs",
    "deploy": "node scripts/deploy.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
