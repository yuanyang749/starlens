AUTH_SECRET=
NEXTAUTH_URL=https://starlens.example.com
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
DATABASE_URL=postgres://starlens:change-me@postgres:5432/starlens
TOKEN_ENCRYPTION_SECRET=
SYSTEM_AI_API_KEY=
SYSTEM_AI_BASE_URL=
SYSTEM_AI_MODEL=
SYSTEM_AI_PROVIDER_TYPE=openai_compatible
SYSTEM_AI_ENABLED=true
# 可选：同一个网关/apiKey 下的兜底 model——主模型请求失败（超时/5xx/网关抽风）时换这个重试一次。
# 不填就没有兜底，行为跟以前一样。
SYSTEM_AI_FALLBACK_MODEL=
# 可选：OpenAI-compatible 网关要求的额外 Header，必须是 JSON 对象字符串。
SYSTEM_AI_EXTRA_HEADERS=
