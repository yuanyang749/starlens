# 中文注释：Starlens 自托管推荐反代配置，先保留 HTTP 和 ACME challenge，证书签发后再启用 HTTPS server。
server {
    listen 80;
    listen [::]:80;
    server_name starlens.example.com;

    location ^~ /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
        default_type "text/plain";
        allow all;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name starlens.example.com;

    ssl_certificate /usr/local/openresty/nginx/conf/ssl/starlens.example.com/fullchain.pem;
    ssl_certificate_key /usr/local/openresty/nginx/conf/ssl/starlens.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # 托管 MCP 端点兼容路径：将 /mcp 转发到 /api/mcp
    location = /mcp {
        proxy_pass http://127.0.0.1:3333/api/mcp;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    location / {
        proxy_pass http://127.0.0.1:3333;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
