{
  "name": "@starlens/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./db/*": "./src/db/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./routes/*": "./src/routes/*.ts",
    "./server/*": "./src/server/*.ts",
    "./server/ai/ask/*": "./src/server/ai/ask/*.ts"
  },
  "scripts": {
    "test": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:integration": "NODE_ENV=development vitest run \"integration\""
  },
  "dependencies": {
    "@starlens-app/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
