# Deploy configuration — copy to .deploy.env and fill in your values
# .deploy.env is gitignored and should never be committed

# SSH host alias or user@host (must be reachable via `ssh <DEPLOY_HOST>`)
DEPLOY_HOST=your-server

# Absolute path to the project on the remote server
DEPLOY_DIR=/opt/starlens

# Deploy script filename relative to DEPLOY_DIR
DEPLOY_SCRIPT=deploy.sh
